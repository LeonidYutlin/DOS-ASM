    460				     ;-------------
    461				     ; RenderFrame - renders CX	by AX bytes from SI
    462				     ;		      to ES starting from pos DX,
    463				     ;		      with BACKGROUND color attribute
    464				     ; Input:  AX =  height
    465				     ;	       CX =  length
    466				     ;	       DI =  vram offset in bytes
    467				     ; Destr:  BX, DI, SI, CX, AX, BP
    468				     ; Expect: CLD
    469				     ;-------------
