    486	2323  85 C9			     test cx, cx
    487	2325  74 2F			     jz	@@EXIT
    488	2327  85 C0			     test ax, ax
    489	2329  74 2B			     jz	@@EXIT
    490	232B  8B EC			     mov bp, sp
