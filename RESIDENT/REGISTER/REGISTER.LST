    475				     ;-------------
    476				     ; RenderFrame - renders CX	by AX bytes from SI
    477				     ;		      to ES starting from pos DX,
    478				     ;		      with BACKGROUND color attribute
    479				     ; Input:  AX =  height
    480				     ;	       CX =  length
    481				     ;	       DI =  vram offset in bytes
    482				     ; Destr:  BX, DI, SI, CX, AX, BP
    483				     ; Expect: CLD
    484				     ;-------------
