    204				     ; MACRO for RenderFrameLine's repeated code
    205				     ; isn't meant for use outside RenderFrameLine
    206				     RenderLineMode macro firstSymbol, middleSymbol, lastSymbol, loopName
    207						     mov es:word ptr[bx],     firstSymbol
    208						     mov es:byte ptr[bx	+ 1], BACKGROUND
    209						     sub bx, 2
    210						     sub cx, 2
    211						     loopName:
    212							     mov es:word ptr[bx],     middleSymbol
    213							     mov es:byte ptr[bx	+ 1], BACKGROUND
    214							     sub bx, 2
    215							     loop loopName
    216						     mov es:word ptr[bx],     lastSymbol
    217						     mov es:byte ptr[bx	+ 1], BACKGROUND
    218						     jmp @@EXIT
    219							endm
