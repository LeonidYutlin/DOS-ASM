    494				     ;-------------
    495				     ; RenderFrameLine - renders a line	of CX bytes
    496				     ;		      to ES starting from pos DX,
    497				     ;		      with Background color attribute
    498				     ; Input:  AL =  frame part:
    499				     ;		     0 = top,
    500				     ;		     1 = middle,
    501				     ;		     2 = bottom,
    502				     ;		     other = whitespace-filled line
