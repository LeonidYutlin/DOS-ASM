    264				     ; MACRO for RenderFrameLine's repeated code
    265				     ; isn't meant for use outside RenderFrameLine
    266				     RenderLineMode macro firstSymbol, middleSymbol, lastSymbol, loopName
    267						     mov es:word ptr[bx],     firstSymbol
    268						     mov es:byte ptr[bx	+ 1], BACKGROUND
    269						     sub bx, 2
    270						     sub cx, 2
    271						     loopName:
    272							     mov es:word ptr[bx],     middleSymbol
    273							     mov es:byte ptr[bx	+ 1], BACKGROUND
    274							     sub bx, 2
    275							     loop loopName
    276						     mov es:word ptr[bx],     lastSymbol
    277						     mov es:byte ptr[bx	+ 1], BACKGROUND
    278						     jmp @@EXIT
    279							endm
