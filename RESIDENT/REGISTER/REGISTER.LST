    496				     ;-------------
    497				     ; RenderStringEscaped - renders CX	bytes from SI
    498				     ;		      to ES starting from pos DX,
    499				     ;		      with TEXT_COLOR color attribute.
    500				     ;		      When encounters '$' character,
    501				     ;		      shifts in	vram by	one line down,
    502				     ;		      effectively mimicking a newline escape
    503				     ; Input:  SI -> string to render
