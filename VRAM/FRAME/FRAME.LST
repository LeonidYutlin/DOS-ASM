    146				     ; MACRO for RenderFrameLine's repeated code
    147				     ; isn't meant for use outside RenderFrameLine
    148				     RenderLineMode macro firstSymbol, middleSymbol, lastSymbol, loopName
    149						     mov es:word ptr[bx],     firstSymbol
    150						     mov es:byte ptr[bx	+ 1], BACKGROUND
    151						     sub bx, 2
    152						     sub cx, 2
    153						     loopName:
    154							     mov es:word ptr[bx],     middleSymbol
    155							     mov es:byte ptr[bx	+ 1], BACKGROUND
    156							     sub bx, 2
    157							     loop loopName
    158						     mov es:word ptr[bx],     lastSymbol
    159						     mov es:byte ptr[bx	+ 1], BACKGROUND
    160						     jmp @@EXIT
    161							endm
